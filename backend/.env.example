#Server Port
PORT=5000                                                                

#Environment: development or production
NODE_ENV=development  

#Front-End URL
FRONTEND_URL=http://localhost:5173                                       

#Firebase Configuration (get from Firebase Console > Project Settings) 
FIREBASE_SERVICE_ACCOUNT_PATH=./path/to/your-service-account-key.json
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com


MONGODB_URI=mongodb://localhost:27017/velocity                           #MongoDB connection string
GEMINI_API_KEY=your_gemini_api_key                                       #Gemini API key
GROQ_API_KEY=your_groq_api_key                                           #Groq API key
RAPIDAPI_KEY=your_rapidapi_key                                           #Rapid API key
RAPID_HOST=your_rapidapi_host

# Email Configuration (Gmail) - Used for local development 
EMAIL_USER=your_email@gmail.com                                                                                   
EMAIL_PASS=your_app_password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SERVICE_URL=https://your-email-service.vercel.app
EMAIL_API_KEY=your_secure_api_key

REDIS_URL=redis://localhost:6379

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

ALERT_CRON_SCHEDULE=0 */6 * * *
ALERT_TEST_INTERVAL=
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Local development auth bypass (never true in production)
DEV_BYPASS_AUTH=false
DEV_USER_UID=dev-user-001
DEV_USER_EMAIL=dev@example.com

# Two-Factor Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOTP_ENCRYPTION_KEY=your_64_char_hex_string_here

# linkedin
LINKEDIN_CLIENT_ID=your_linkedin_clientId
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_REDIRECT_URI=http://localhost:5000/api/auth/linkedin/callback
